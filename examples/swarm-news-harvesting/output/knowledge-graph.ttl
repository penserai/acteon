# === finding-4c8786e8-03b3-4a93-9e30-9f6444444c86 ===
<urn:tesserai:twin:finding-4c8786e8-03b3-4a93-9e30-9f6444444c86> <http://tesserai.io/ontology/createdAt> "2026-03-24T23:53:37.407824Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
	<http://tesserai.io/ontology/topics> "[\"Research EU AI policy developments and industry impact\",\"researcher\"]" ;
	<http://tesserai.io/ontology/run_id> "8f7f386a-a849-42b5-9c48-3606961dff7d" ;
