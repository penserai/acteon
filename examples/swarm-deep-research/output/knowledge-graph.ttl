<urn:tesserai:twin:memory-f9366acc-c74d-4d7d-aac4-5b209e9ecd9f> <http://tesserai.io/ontology/createdAt> "2026-03-28T15:12:42.187212Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
