<urn:tesserai:twin:memory-a71d517c-3988-42a9-837c-df82122e15af> <http://tesserai.io/ontology/createdAt> "2026-03-28T15:14:18.823315Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
