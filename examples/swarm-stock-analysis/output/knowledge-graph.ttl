# === finding-1c6610c6-5a5f-47ee-82f3-a22e72350538 ===
<urn:tesserai:twin:finding-1c6610c6-5a5f-47ee-82f3-a22e72350538> <http://tesserai.io/ontology/createdAt> "2026-03-25T00:21:09.209149Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
