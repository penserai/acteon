# === finding-d8150a13-97a7-4cb2-a73a-4569b1d0559b ===
<urn:tesserai:twin:finding-d8150a13-97a7-4cb2-a73a-4569b1d0559b> <http://tesserai.io/ontology/createdAt> "2026-03-26T14:45:52.404917Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
	<http://tesserai.io/ontology/topics> "[\"Research Amazon Q4 2025 Earnings\",\"researcher\"]" ;
	<http://tesserai.io/ontology/run_id> "0992cacc-298d-4773-9006-51d343f922be" ;
