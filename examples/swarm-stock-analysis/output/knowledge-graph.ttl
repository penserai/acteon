<urn:tesserai:twin:memory-5cc23e95-9914-4c35-a587-9edbbb1f3cb9> <http://tesserai.io/ontology/createdAt> "2026-03-27T17:12:51.149996Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
