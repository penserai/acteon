# === finding-4b948e5d-cb01-4df7-9e07-c20ebed17b80 ===
<urn:tesserai:twin:finding-4b948e5d-cb01-4df7-9e07-c20ebed17b80> <http://tesserai.io/ontology/createdAt> "2026-03-28T14:45:32.577079Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
