# === finding-e279f95a-9d41-48f5-8ef8-0e2b634fb44f ===
<urn:tesserai:twin:finding-e279f95a-9d41-48f5-8ef8-0e2b634fb44f> <http://tesserai.io/ontology/createdAt> "2026-03-25T00:46:40.502634Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
