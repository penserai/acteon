# === memory-e0fe3f83-445f-4c44-ad45-05e29da87ba1 ===
<urn:tesserai:twin:memory-e0fe3f83-445f-4c44-ad45-05e29da87ba1> <http://tesserai.io/ontology/createdAt> "2026-03-26T14:45:52.40411Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
	<http://tesserai.io/ontology/topics> "[\"Research Amazon Q4 2025 Earnings\",\"Research Amazon sector impact\",\"researcher\"]" ;
