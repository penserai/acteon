<urn:tesserai:twin:memory-b22ebbd4-21d2-4ebb-bb39-5703a4aa2a1c> <http://tesserai.io/ontology/createdAt> "2026-03-27T17:11:10.49393Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
