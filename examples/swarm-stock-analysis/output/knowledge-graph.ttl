# === finding-9b5d0dd3-0fd1-4cf1-927d-4d58df40c52e ===
<urn:tesserai:twin:finding-9b5d0dd3-0fd1-4cf1-927d-4d58df40c52e> <http://tesserai.io/ontology/createdAt> "2026-03-24T23:53:07.667654Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
	<http://tesserai.io/ontology/topics> "[\"Write Company Summary Reports\",\"coder\"]" ;
	<http://tesserai.io/ontology/run_id> "ad1c0b95-d5b5-4b81-8bdc-47c8640c8942" ;
