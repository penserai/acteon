# === finding-3331ba49-ac0c-4e2e-8b4e-6c8845aa07b7 ===
<urn:tesserai:twin:finding-3331ba49-ac0c-4e2e-8b4e-6c8845aa07b7> <http://tesserai.io/ontology/createdAt> "2026-03-27T17:04:30.652183Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
