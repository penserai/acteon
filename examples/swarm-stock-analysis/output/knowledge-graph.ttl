<urn:tesserai:twin:memory-21c4bd3d-96a5-45f2-885c-4993b5f06f2f> <http://tesserai.io/ontology/createdAt> "2026-03-26T14:47:29.112464Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
